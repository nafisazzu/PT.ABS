// ── TABS ──────────────────────────────────────────────────────────────
function switchTab(t) {
  document.querySelectorAll('.soal-tab').forEach(function(el){ el.classList.remove('active'); });
  document.querySelectorAll('.soal-panel').forEach(function(el){ el.classList.remove('active'); });
  document.querySelector('.soal-tab.t-' + t).classList.add('active');
  document.getElementById('panel-' + t).classList.add('active');
}

// ── ADD / UPDATE ──────────────────────────────────────────────────────
function addSoal(t) {
  var q = (document.getElementById('fq-' + t).value || '').trim();
  if (!q) { showToast('Pertanyaan wajib diisi!', true); return; }

  var entry;
  if (t === 'vs') {
    entry = { q: q, tipe: document.getElementById('fk-' + t).value || 'paham' };
  } else {
    var A = (document.getElementById('fA-' + t).value || '').trim();
    var B = (document.getElementById('fB-' + t).value || '').trim();
    var C = (document.getElementById('fC-' + t).value || '').trim();
    var D = (document.getElementById('fD-' + t).value || '').trim();
    var k = document.getElementById('fk-' + t).value;
    if (!A || !B) { showToast('Minimal isi pilihan A dan B!', true); return; }
    if (!k) { showToast('Pilih kunci jawaban!', true); return; }
    entry = { q:q, A:A, B:B, C:C, D:D };
  }

  var idx = parseInt(document.getElementById('fidx-' + t).value);
  if (idx >= 0) {
    soalDB[t][idx] = entry;
    showToast('<i class="fas fa-check-circle"></i> Soal berhasil diperbarui!');
  } else {
    soalDB[t].push(entry);
    showToast('<i class="fas fa-check-circle"></i> Soal berhasil ditambahkan!');
  }
  save(t);
  resetForm(t);
  renderList(t);
}

// ── EDIT ──────────────────────────────────────────────────────────────
function editSoal(t, idx) {
  var s = soalDB[t][idx];
  if (!s) return;
  document.getElementById('fq-' + t).value = s.q;
  if (t === 'vs') {
    document.getElementById('fk-' + t).value = s.tipe || 'paham';
  } else {
    document.getElementById('fA-' + t).value = s.A || '';
    document.getElementById('fB-' + t).value = s.B || '';
    document.getElementById('fC-' + t).value = s.C || '';
    document.getElementById('fD-' + t).value = s.D || '';
    document.getElementById('fk-' + t).value = s.k || '';
  }
  document.getElementById('fidx-' + t).value = idx;
  document.getElementById('fb-' + t).textContent = 'Update';
  document.getElementById('fi-' + t).className  = 'fas fa-save';
  document.getElementById('ft-' + t).textContent = 'Edit No.' + (idx+1) + ' — ' + LABELS[t];
  document.querySelectorAll('#sl-' + t + ' .soal-card').forEach(function(c,i){ c.classList.toggle('editing', i===idx); });
  document.querySelector('#panel-' + t + ' .soal-form').scrollIntoView({behavior:'smooth',block:'start'});
}

// ── DELETE ────────────────────────────────────────────────────────────
function deleteSoal(t, idx) {
  if (!confirm('Hapus soal No.' + (idx+1) + '?')) return;
  soalDB[t].splice(idx, 1);
  save(t);
  renderList(t);
  showToast('<i class="fas fa-trash-alt"></i> Soal dihapus!');
}

function clearAll(t) {
  if (!soalDB[t].length) { showToast('Belum ada soal.', true); return; }
  if (!confirm('Hapus semua ' + soalDB[t].length + ' soal ' + LABELS[t] + '?')) return;
  soalDB[t] = [];
  save(t);
  renderList(t);
  showToast('<i class="fas fa-trash-alt"></i> Semua soal dihapus!');
}

function cancelEdit(t) { resetForm(t); }

function resetForm(t) {
  document.getElementById('fq-' + t).value = '';
  if (t !== 'vs') {
    ['A','B','C','D'].forEach(function(l){ var el = document.getElementById('f' + l + '-' + t); if(el) el.value=''; });
    document.getElementById('fk-' + t).value = '';
  } else {
    document.getElementById('fk-' + t).value = 'paham';
  }
  document.getElementById('fidx-' + t).value = '-1';
  document.getElementById('fb-' + t).textContent = t==='vs' ? 'Tambah Pernyataan' : 'Tambah Soal';
  document.getElementById('fi-' + t).className  = 'fas fa-plus-circle';
  document.getElementById('ft-' + t).textContent = 'Tambah ' + (t==='vs'?'Pernyataan':'Soal') + ' — ' + LABELS[t];
  document.querySelectorAll('#sl-' + t + ' .soal-card').forEach(function(c){ c.classList.remove('editing'); });
}

// ── RESET ALL ke default ──────────────────────────────────────────────
function resetAllSoal() {
  if (!confirm('Reset semua soal ke data default?\nPerubahan yang sudah dibuat akan hilang.')) return;
  var defs = {nh:DEF_NHP, pw:DEF_NHP, ri:DEF_RI, vs:DEF_VS};
  ['nh','pw','ri','vs'].forEach(function(t) {
    soalDB[t] = JSON.parse(JSON.stringify(defs[t]));
    localStorage.setItem(SK[t], JSON.stringify(soalDB[t]));
    renderList(t);
  });
  showToast('<i class="fas fa-undo"></i> Semua soal direset ke default!');
}

// ── RENDER ────────────────────────────────────────────────────────────
function renderList(t) {
  var list = soalDB[t];
  var container = document.getElementById('sl-' + t);
  var countEl   = document.getElementById('sc-' + t);
  var tabCount  = document.getElementById('tc-' + t);
  if (!container) return;

  var unit = t === 'vs' ? 'pernyataan' : 'soal';
  countEl.innerHTML  = '<i class="fas fa-list-ol"></i> ' + list.length + ' ' + unit;
  if (tabCount) tabCount.textContent = list.length || '';

  if (!list.length) {
    container.innerHTML = '<div class="soal-empty"><i class="fas fa-inbox"></i>Belum ada ' + unit + '. Tambahkan menggunakan form di atas.</div>';
    return;
  }

  if (t === 'vs') {
    container.innerHTML = list.map(function(s, i) {
      var tipeLabel = s.tipe === 'setuju'
        ? '<span class="soal-card-vs"><i class="fas fa-handshake" style="font-size:9px"></i> Saya Setuju / Tidak Setuju</span>'
        : '<span class="soal-card-vs"><i class="fas fa-check-circle" style="font-size:9px"></i> Paham / Tidak Paham</span>';
      return '<div class="soal-card">' +
        '<div class="soal-card-actions">' +
          '<button class="btn-soal-edit" onclick="editSoal(\'vs\',' + i + ')"><i class="fas fa-pen"></i> Edit</button>' +
          '<button class="btn-soal-del"  onclick="deleteSoal(\'vs\',' + i + ')"><i class="fas fa-trash-alt"></i></button>' +
        '</div>' +
        '<div class="soal-card-header"><div class="soal-num c-vs">' + (i+1) + '</div><div class="soal-card-text">' + s.q + '</div></div>' +
        '<div class="soal-card-opts">' + tipeLabel + '</div>' +
      '</div>';
    }).join('');
  } else {
    var numCls = t==='pw' ? ' c-pw' : t==='ri' ? ' c-ri' : '';
    container.innerHTML = list.map(function(s, i) {
      var opts = ['A','B','C','D'].map(function(l) {
        if (!s[l]) return '';
        var isK = s.k === l;
        return '<span class="soal-card-opt' + (isK?' kunci':'') + '">' + l + '. ' + s[l] + '</span>';
      }).join('');
      return '<div class="soal-card">' +
        '<div class="soal-card-actions">' +
          '<button class="btn-soal-edit" onclick="editSoal(\'' + t + '\',' + i + ')"><i class="fas fa-pen"></i> Edit</button>' +
          '<button class="btn-soal-del"  onclick="deleteSoal(\'' + t + '\',' + i + ')"><i class="fas fa-trash-alt"></i></button>' +
        '</div>' +
        '<div class="soal-card-header"><div class="soal-num' + numCls + '">' + (i+1) + '</div><div class="soal-card-text">' + s.q + '</div></div>' +
        '<div class="soal-card-opts">' + opts + '</div>' +
      '</div>';
    }).join('');
  }
}

// ── TOAST ─────────────────────────────────────────────────────────────
function showToast(msg, isError) {
  var t = document.getElementById('toast');
  t.innerHTML = msg;
  t.style.background = isError ? 'var(--accent2)' : 'var(--navy)';
  t.classList.add('show');
  setTimeout(function(){ t.classList.remove('show'); }, 3000);
}

// ── SIDEBAR ───────────────────────────────────────────────────────────
(function() {
  var name = localStorage.getItem('userName') || 'User';
  ['userNameDisplay','sidebarUserName'].forEach(function(id){ var el=document.getElementById(id); if(el) el.textContent=name; });
  var av = document.getElementById('sidebarAvatarLetter'); if(av) av.textContent = name.charAt(0).toUpperCase();
})();
function toggleSidebar(){ document.getElementById('sidebar').classList.toggle('open'); document.getElementById('overlay').classList.toggle('open'); }
function logout(){ if(confirm('Yakin ingin logout?')){ localStorage.removeItem('userName'); window.location.href='index.html'; } }

// ── INIT ──────────────────────────────────────────────────────────────
loadAll();
</script>
