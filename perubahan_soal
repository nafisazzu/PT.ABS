<!-- MAIN -->
<div class="main">
  <div class="topbar">
    <div class="topbar-left">
      <h5>Arta Integrated Manajemen System</h5>
      <span>Sistem Informasi Keselamatan Kerja</span>
    </div>
    <div class="topbar-right">
      <button class="topbar-btn"><i class="fas fa-bell"></i></button>
      <div class="topbar-user">
        <div class="topbar-avatar"><i class="fas fa-user"></i></div>
        <span class="topbar-uname" id="userNameDisplay">User</span>
      </div>
    </div>
  </div>

  <div class="content">
    <a href="laporan_induksi.html" class="back-btn">
      <i class="fas fa-arrow-left"></i> Kembali ke Laporan Induksi
    </a>

    <div class="page-header">
      <div class="page-title">
        <div class="title-icon"><i class="fas fa-pen-to-square"></i></div>
        Ubah Soal Induksi K3LH
      </div>
      <div class="page-sub">Kelola soal untuk setiap jenis induksi — perubahan otomatis tersimpan di browser</div>
    </div>

    <!-- CARD UTAMA -->
    <div class="data-card">
      <div class="card-head">
        <div class="card-head-left">
          <div class="card-head-icon chi-purple"><i class="fas fa-question-circle"></i></div>
          <div>
            <div class="card-head-title">Bank Soal Induksi</div>
            <div class="card-head-sub">Pilih tab jenis induksi untuk mengelola soal</div>
          </div>
        </div>
        <button onclick="resetAllSoal()" style="padding:7px 14px;border-radius:9px;background:rgba(255,78,106,.10);color:#b91c1c;border:1px solid rgba(255,78,106,.2);font-size:12px;font-weight:600;cursor:pointer;font-family:'DM Sans',sans-serif;display:inline-flex;align-items:center;gap:6px;">
          <i class="fas fa-undo"></i> Reset ke Default
        </button>
      </div>
      <div class="card-body">

        <!-- 4 Tabs -->
        <div class="soal-tabs">
          <button class="soal-tab t-nh active" onclick="switchTab('nh')">
            <i class="fas fa-user-plus"></i> New Hire / Pengawas NH
            <span class="tab-count" id="tc-nh">0</span>
          </button>
          <button class="soal-tab t-pw" onclick="switchTab('pw')">
            <i class="fas fa-hard-hat"></i> Induksi Pengawas
            <span class="tab-count" id="tc-pw">0</span>
          </button>
          <button class="soal-tab t-ri" onclick="switchTab('ri')">
            <i class="fas fa-redo"></i> Re-Induksi
            <span class="tab-count" id="tc-ri">0</span>
          </button>
          <button class="soal-tab t-vs" onclick="switchTab('vs')">
            <i class="fas fa-id-badge"></i> Visitor
            <span class="tab-count" id="tc-vs">0</span>
          </button>
        </div>

        <!-- Panel NH -->
